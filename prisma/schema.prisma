// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String @id @default(uuid())
  email    String @unique
  name     String
  password String

  role   Role
  status AccountStatus @default(PENDING_VERIFICATION)

  previousPassword String?

  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt
  otp                     Otp[]
  freelancerProfile       FreelancerProfile?
  jobs                    Job[]              @relation("EmployerJobs")
  applications            Application[]      @relation("FreelancerApplications")
  payments                Payment[]          @relation("EmployerPayments")
  freelancerPayments      Payment[]          @relation("FreelancerPayments")
  notifications           Notification[]
  employerConversations   Conversation[]     @relation("EmployerConversations")
  freelancerConversations Conversation[]     @relation("FreelancerConversations")
  messages                Message[]

  @@index([role])
  @@map("users")
}

model Otp {
  id     String  @id @default(uuid())
  userId String
  code   Int
  type   OtpType

  expiresAt DateTime
  isUsed    Boolean  @default(false)

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([code])
  @@map("otp")
}

model FreelancerProfile {
  id           String   @id @default(uuid())
  userId       String   @unique
  title        String?
  bio          String?
  skills       String[]
  hourlyRate   Decimal? @db.Decimal(10, 2)
  availability Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("freelancer_profiles")
}

model Job {
  id             String    @id @default(uuid())
  employerId     String
  title          String
  description    String
  skillsRequired String[]
  budget         Decimal   @db.Decimal(10, 2)
  jobType        JobType
  status         JobStatus @default(OPEN)
  aiEnhanced     Boolean   @default(false) @map("ai_enhanced")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  employer     User          @relation("EmployerJobs", fields: [employerId], references: [id])
  applications Application[]

  @@index([employerId])
  @@index([status])
  @@map("jobs")
}

model Application {
  id             String            @id @default(uuid())
  jobId          String
  freelancerId   String
  coverNote      String
  status         ApplicationStatus @default(PENDING)
  proposedBudget Decimal           @db.Decimal(10, 2)
  aiMatchScore   Decimal?          @db.Decimal(5, 2)
  aiNote         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  job        Job      @relation(fields: [jobId], references: [id])
  freelancer User     @relation("FreelancerApplications", fields: [freelancerId], references: [id])
  payment    Payment?

  @@unique([jobId, freelancerId])
  @@index([jobId])
  @@index([freelancerId])
  @@index([status])
  @@map("applications")
}

model Payment {
  id            String @id @default(uuid())
  applicationId String @unique

  employerId            String
  freelancerId          String
  amount                Decimal       @db.Decimal(10, 2)
  currency              String        @default("usd")
  stripePaymentIntentId String        @unique
  status                PaymentStatus @default(PENDING)
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  application Application @relation(fields: [applicationId], references: [id])

  employer   User @relation("EmployerPayments", fields: [employerId], references: [id])
  freelancer User @relation("FreelancerPayments", fields: [freelancerId], references: [id])

  @@index([employerId])
  @@index([status])
  @@map("payments")
}

model Notification {
  id         String           @id @default(uuid())
  receiverId String
  type       NotificationType
  title      String
  body       String
  isRead     Boolean          @default(false)
  createdAt  DateTime         @default(now())

  user User @relation(fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([receiverId])
  @@index([isRead])
  @@map("notifications")
}

model Conversation {
  id String @id @default(uuid())

  employerId   String
  freelancerId String
  createdAt    DateTime @default(now())

  employer   User      @relation("EmployerConversations", fields: [employerId], references: [id])
  freelancer User      @relation("FreelancerConversations", fields: [freelancerId], references: [id])
  messages   Message[]

  @@unique([employerId, freelancerId])
  @@index([employerId])
  @@index([freelancerId])
  @@map("conversations")
}

model Message {
  id             String   @id @default(uuid())
  conversationId String
  senderId       String
  content        String
  isRead         Boolean  @default(false)
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id])
  sender       User         @relation(fields: [senderId], references: [id])

  @@index([conversationId])
  @@map("messages")
}

enum Role {
  EMPLOYER
  FREELANCER
  ADMIN
  SUPER_ADMIN
}

enum AccountStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  BANNED
  PENDING_VERIFICATION
  DELETED
}

enum OtpType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
  RESEND_OTP
}

enum JobType {
  FIXED
  HOURLY
}

enum JobStatus {
  OPEN
  CLOSED
  FILLED
}

enum ApplicationStatus {
  PENDING
  REVIEWED
  SHORTLISTED
  REJECTED
  HIRED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum NotificationType {
  NEW_APPLICATION
  NEW_MESSAGE
  STATUS_CHANGE
  HIRED
  PAYMENT_RECEIVED
  SYSTEM
}
